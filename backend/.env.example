# ── Core ────────────────────────────────────────────────────
LIVE_MODE=false
API_HOST=0.0.0.0
API_PORT=8001
DB_PATH=trading.db
LOG_LEVEL=INFO

# ── Engine ──────────────────────────────────────────────────
SYSTEM_CYCLE_SECONDS=120
MAX_CONCURRENT_TRADES=100
ENABLE_BACKGROUND_LOOP=true
TRADE_UPDATE_INTERVAL=60

# ── Trade Style ─────────────────────────────────────────────
# SCALP = 5–30 min holds, SL=0.5%, TS=0.35% | high frequency
# SWING = 1–4 hour holds, SL=1.5%, TS=1.0%  | balanced (default)
# HOLD  = 4–24 hour holds, SL=3.0%, TS=2.0% | trend following
TRADE_STYLE=SWING

# ── Risk overrides (leave blank to use TRADE_STYLE defaults) ──
# STOP_LOSS_PCT=1.5
# TRAILING_STOP_PCT=1.0
# TS_ACTIVATION_PCT=0.8
BROKER_FEE_PCT=0.1

# ── Data ────────────────────────────────────────────────────
EODHD_API_KEY=your_eodhd_api_key_here

# ── Broker: IG Markets ──────────────────────────────────────
IG_API_KEY=your_ig_api_key
IG_USER=your_ig_username
IG_PASSWORD=your_ig_password

# ── Notifications ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+0987654321

RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_TO_EMAIL=you@yourdomain.com
